    "lint:self": "node bin/voice-md.js lint examples/VOICE.md"
  },
  "exports": {
    ".": "./src/index.js",
    "./linter": "./src/linter.js",
    "./diff": "./src/diff.js",
    "./exporters": "./src/exporters.js"
