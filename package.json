  "description": "Format specification for describing a brand's communicational identity to AI agents. VOICE.md is to copy and tone what DESIGN.md is to visual identity.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "voice-md": "bin/voice-md.js",
    "voicemd": "bin/voice-md.js"
  },
  "scripts": {
